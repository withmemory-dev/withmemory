{
  "name": "@withmemory/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test:ranking": "tsx scripts/test-ranking.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate --config=drizzle.config.prod.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:all": "pnpm db:migrate && pnpm db:migrate:prod",
    "db:create-test-key": "tsx scripts/create-test-key.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.80.0"
  }
}
