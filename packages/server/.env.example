# WithMemory Server — Environment Variables Template
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.
#
# For production secrets that the Worker needs at runtime,
# use `wrangler secret put VAR_NAME` instead of putting them here.
# This file is only used by Drizzle Kit migrations and local dev.

# ─────────────────────────────────────────────────────────────────────────────
# Local development database (Supabase running in Docker via `supabase start`)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Production database (Supabase Cloud — withmemory-prod project)
#
# Use the DIRECT CONNECTION string (port 5432), not the pooler.
# Migrations require a real session connection, which the pooler does not support.
# Get this from supabase.com/dashboard → withmemory-prod → Settings → Database
# ─────────────────────────────────────────────────────────────────────────────
PROD_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
