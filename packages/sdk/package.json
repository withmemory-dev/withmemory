{
  "name": "@withmemory/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for WithMemory — persistent memory for AI agents",
  "license": "Apache-2.0",
  "author": "WithMemory <hello@withmemory.dev>",
  "homepage": "https://withmemory.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/withmemory-dev/withmemory",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/withmemory-dev/withmemory/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "llm",
    "typescript",
    "sdk",
    "vector",
    "embedding",
    "recall"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.2"
  }
}
